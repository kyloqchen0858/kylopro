# ============================================================
# Kylopro-Nexus 密钥配置模板
# 复制为 .env 并填写真实值，严禁提交 .env 到 Git
# ============================================================

# === 双核大脑：DeepSeek（云端高智商） ===
# 从 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek/deepseek-reasoner

# === 双核大脑：Ollama（本地低耗能） ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:latest

# === 扩展槽：未来填入即可激活 ===
# Anthropic Claude（创意写作）
ANTHROPIC_API_KEY=

# OpenAI GPT（通用任务）
OPENAI_API_KEY=

# Gemini（多模态 + Gemini-CLI 协作入口）
GEMINI_API_KEY=

# OpenRouter（全模型网关）
OPENROUTER_API_KEY=

# SiliconFlow / 硅基流动（国内低成本推理）
SILICONFLOW_API_KEY=

# Moonshot / Kimi
MOONSHOT_API_KEY=

# === 通道配置 ===
# Kylopro 读取 ~/.nanobot/config.json 中的 Telegram 配置
# 也可在此覆盖（二选一，此处优先级更高）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === 安全配置 ===
# 危险操作确认模式: cli（命令行询问）| telegram（Telegram 授权）
SAFETY_CONFIRM_MODE=cli

# === 美容师专用：代码审查模型 ===
# 默认用 deepseek-coder，专为代码分析优化
# 正式密钥上线后替换 your_xxxxx_here，留空时回退到 DEEPSEEK_API_KEY
CODE_REVIEW_API_KEY=your_code_review_api_key_here
CODE_REVIEW_MODEL=deepseek-coder
CODE_REVIEW_BASE_URL=https://api.deepseek.com
