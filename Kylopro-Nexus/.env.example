# ================================================================
# Kylopro-Nexus 环境变量配置模板
# 使用方法：复制此文件为 .env，然后填入你的真实 API keys
# 注意：.env 文件已在 .gitignore 中，不会被提交到 Git
# ================================================================

# ----------------------------------------------------------------
# 主力云端 API - DeepSeek（推荐，性价比最高）
# ----------------------------------------------------------------
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat

# ----------------------------------------------------------------
# 视觉任务 API - 智谱 GLM-4V（处理图片/截图）
# ----------------------------------------------------------------
# 申请地址：https://open.bigmodel.cn/
GLM_API_KEY=your-glm-key-here
GLM_MODEL=glm-4v-flash

# ----------------------------------------------------------------
# 降级网关 - OpenRouter（DeepSeek 不可用时自动切换）
# ----------------------------------------------------------------
# 申请地址：https://openrouter.ai/
# 强烈建议配置，作为备用防止 DeepSeek 宕机时断线
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_MODEL=deepseek/deepseek-chat

# ----------------------------------------------------------------
# 本地模型 - Ollama（本机运行，零费用，隐私保护）
# ----------------------------------------------------------------
# 安装 Ollama：https://ollama.com/
# 下载模型：ollama pull deepseek-r1:latest
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:latest

# Ollama 云端模型（通过 ollama.com 拉取，按需切换）
OLLAMA_CLOUD_MODEL=llama3.3:latest

# ----------------------------------------------------------------
# Telegram Bot 配置
# ----------------------------------------------------------------
# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# 你的 Telegram 用户 ID（让 Kylo 只响应你）
TELEGRAM_OWNER_ID=your-telegram-user-id-here

# ----------------------------------------------------------------
# GitHub 配置（用于 github_skill_manager）
# ----------------------------------------------------------------
GITHUB_TOKEN=ghp-your-github-token-here
GITHUB_REPO=kyloqchen0858/kylopro

# GitHub Skill 仓库（用于技能管理器下载/上传技能）
GITHUB_SKILL_TOKEN=ghp-your-github-skill-token-here
GITHUB_SKILL_OWNER=kyloqchen0858
GITHUB_SKILL_REPO=Kylopro-Skills-Repo

# ----------------------------------------------------------------
# 扩展 AI 接口（填入 key 即可激活）
# ----------------------------------------------------------------

# Gemini（多模态视觉备用方案）
GEMINI_API_KEY=

# OpenAI GPT（通用任务）
OPENAI_API_KEY=

# Anthropic Claude（创意写作）
ANTHROPIC_API_KEY=

# SiliconFlow / 硅基流动（国内低成本推理）
SILICONFLOW_API_KEY=

# Moonshot / Kimi
MOONSHOT_API_KEY=

# ----------------------------------------------------------------
# 其他配置
# ----------------------------------------------------------------
# 打断关键词（触发这些词时 Kylo 会暂停当前任务优先响应）
INTERRUPT_KEYWORDS=停,等一下,先别,重要,紧急,stop,wait,urgent

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# Kylopro 工作目录
# 相对路径示例（Linux/macOS/Docker）：./Kylopro-Nexus
# 绝对路径示例（Windows）：C:/Users/qianchen/Desktop/nanobot/Kylopro-Nexus
KYLOPRO_ROOT=./Kylopro-Nexus

# 危险操作确认模式: cli（命令行询问）| telegram（Telegram 授权）
SAFETY_CONFIRM_MODE=cli

# 代码审查模型（code_beautician skill 使用）
CODE_REVIEW_API_KEY=your_code_review_api_key_here
CODE_REVIEW_MODEL=deepseek-coder
CODE_REVIEW_BASE_URL=https://api.deepseek.com
