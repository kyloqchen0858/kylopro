# 统一换行符为 LF，避免 Windows/Linux 混用导致文件污染
* text=auto eol=lf

# Python 文件强制 LF
*.py text eol=lf

# Markdown/文本文件强制 LF
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.env text eol=lf

# 二进制文件不转换
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
